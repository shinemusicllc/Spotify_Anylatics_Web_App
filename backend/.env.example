# -- Database --
DATABASE_URL=postgresql+asyncpg://postgres:password@127.0.0.1:5432/spoticheck

# -- Spotify API app credentials (optional but recommended) --
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_HTTP_TIMEOUT_SECONDS=8

# -- Legacy (not required for current backend flow) --
SPOTIFY_EMAIL=
SPOTIFY_PASSWORD=

# -- Crawl Settings --
CRAWL_DELAY_SECONDS=0.2
MAX_RETRIES=1
RATE_LIMIT_PER_MINUTE=60
PLAYLIST_PAGE_SIZE=100
PLAYLIST_MAX_TRACKS=2000
PLAYWRIGHT_ENABLE_FALLBACK=true
PLAYWRIGHT_INLINE_FALLBACK=false
PLAYWRIGHT_FAST_FAIL_ERRORS=false
PLAYWRIGHT_TIMEOUT_MS=20000
PLAYWRIGHT_WAIT_MS=800
PLAYWRIGHT_MAX_CONCURRENCY=4
PLAYWRIGHT_RETRIES=1
PLAYWRIGHT_HYDRATE_TIMEOUT_MS=8000
PLAYWRIGHT_ALBUM_MAX_TRACKS=80

# -- CORS --
FRONTEND_URL=http://localhost:8080

# -- App --
SECRET_KEY=change-me-in-production
DEBUG=false
AUTO_INIT_DB=true
SERVE_FRONTEND=true
FRONTEND_DIR=../frontend

# -- JWT / Auth --
JWT_SECRET_KEY=change-me-in-production-jwt
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
